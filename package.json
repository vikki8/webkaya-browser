{
  "name": "@webkaya/sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Client-side AI agent sandboxes — run agent-generated code in the end user's browser with policy governance, snapshots, fork, and replay.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/runtime/worker/worker-entry.d.ts",
      "import": "./dist/runtime/worker/worker-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
